{
  "name": "browser-sample-analyzer",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "build:hardened": "npm run build && node scripts/harden-build.mjs",
    "release:zip": "npm run build:hardened && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-extension.ps1",
    "preview": "vite preview --host 127.0.0.1",
    "license:promo": "node scripts/generate-license.mjs promo",
    "license:permanent": "node scripts/generate-license.mjs permanent"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wavesurfer.js": "^7.9.9"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "javascript-obfuscator": "^4.1.1",
    "vitest": "^3.2.4"
  }
}
